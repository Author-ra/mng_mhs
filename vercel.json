{
  "version": 2,
  "buildCommand": "composer install --no-dev --optimize-autoloader",
  "outputDirectory": "public",
  "functions": {
    "public/index.php": {
      "runtime": "vercel-php@0.6.0"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/public/index.php"
    }
  ],
  "env": {
    "CI_ENVIRONMENT": "production",
    "APP_ENV": "production"
  }
}
